{% doc %}
  @prompt
    Create a statistics section with 3 columns showing animated percentage numbers. Critical requirement: animation must trigger on scroll using IntersectionObserver.
    
    Technical implementation:
    - Use a simple div wrapper with class "stats-animation-wrapper" and data-stats-init attribute
    - Each number has data-target="80" and data-suffix="%" attributes
    - Plain vanilla JavaScript (NO custom elements, NO class extends HTMLElement)
    - IntersectionObserver watches the wrapper div
    - When wrapper enters viewport (threshold 0.2), start count-up animation
    - Use requestAnimationFrame for smooth 0-to-target counting with easeOutQuart
    - Include both DOMContentLoaded listener AND immediate execution for already-loaded content
    - Add Shopify theme editor event listeners: shopify:section:load and shopify:block:select
    
    Layout:
    - Centered heading "Benefícios comprovados, resultados comprovados"
    - 3 equal columns with large bold numbers (80%, 75%, 74%)
    - Subtitle below each number
    - Small italic description text below subtitle
    - Clean minimal design, white background
    
    All editable: heading, 3 stats (number/subtitle/description), colors, sizes, animation duration
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-section-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    padding: {{ block.settings.section_padding }}px 20px;
    background-color: {{ block.settings.background_color }};
    text-align: center;
  }

  .ai-stats-heading-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 {{ block.settings.heading_spacing }}px;
    font-weight: 700;
  }

  .ai-stats-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.column_gap }}px;
    max-width: {{ block.settings.max_width }}px;
    margin: 0 auto;
  }

  .ai-stats-column-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: {{ block.settings.column_padding }}px;
  }

  .ai-stats-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: 700;
    color: {{ block.settings.number_color }};
    margin: 0 0 {{ block.settings.number_spacing }}px;
    line-height: 1;
  }

  .ai-stats-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 {{ block.settings.subtitle_spacing }}px;
    font-weight: 600;
  }

  .ai-stats-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    font-style: italic;
    margin: 0;
    line-height: 1.4;
  }

  @media screen and (max-width: 749px) {
    .ai-stats-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.column_gap | times: 1.5 }}px;
    }

    .ai-stats-heading-{{ ai_gen_id }} {
      font-size: {{ block.settings.heading_size | times: 0.7 }}px;
    }

    .ai-stats-number-{{ ai_gen_id }} {
      font-size: {{ block.settings.number_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div
  class="ai-stats-section-{{ ai_gen_id }} stats-animation-wrapper"
  data-stats-init
  {{ block.shopify_attributes }}
>
  {% if block.settings.heading != blank %}
    <h2 class="ai-stats-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
  {% endif %}

  <div class="ai-stats-grid-{{ ai_gen_id }}">
    <div class="ai-stats-column-{{ ai_gen_id }}">
      <div
        class="ai-stats-number-{{ ai_gen_id }}"
        data-target="{{ block.settings.stat_1_number }}"
        data-suffix="{{ block.settings.stat_1_suffix }}"
      >
        0{{ block.settings.stat_1_suffix }}
      </div>
      {% if block.settings.stat_1_subtitle != blank %}
        <div class="ai-stats-subtitle-{{ ai_gen_id }}">{{ block.settings.stat_1_subtitle }}</div>
      {% endif %}
      {% if block.settings.stat_1_description != blank %}
        <div class="ai-stats-description-{{ ai_gen_id }}">{{ block.settings.stat_1_description }}</div>
      {% endif %}
    </div>

    <div class="ai-stats-column-{{ ai_gen_id }}">
      <div
        class="ai-stats-number-{{ ai_gen_id }}"
        data-target="{{ block.settings.stat_2_number }}"
        data-suffix="{{ block.settings.stat_2_suffix }}"
      >
        0{{ block.settings.stat_2_suffix }}
      </div>
      {% if block.settings.stat_2_subtitle != blank %}
        <div class="ai-stats-subtitle-{{ ai_gen_id }}">{{ block.settings.stat_2_subtitle }}</div>
      {% endif %}
      {% if block.settings.stat_2_description != blank %}
        <div class="ai-stats-description-{{ ai_gen_id }}">{{ block.settings.stat_2_description }}</div>
      {% endif %}
    </div>

    <div class="ai-stats-column-{{ ai_gen_id }}">
      <div
        class="ai-stats-number-{{ ai_gen_id }}"
        data-target="{{ block.settings.stat_3_number }}"
        data-suffix="{{ block.settings.stat_3_suffix }}"
      >
        0{{ block.settings.stat_3_suffix }}
      </div>
      {% if block.settings.stat_3_subtitle != blank %}
        <div class="ai-stats-subtitle-{{ ai_gen_id }}">{{ block.settings.stat_3_subtitle }}</div>
      {% endif %}
      {% if block.settings.stat_3_description != blank %}
        <div class="ai-stats-description-{{ ai_gen_id }}">{{ block.settings.stat_3_description }}</div>
      {% endif %}
    </div>
  </div>
</div>

<script>
  (function() {
    const duration = {{ block.settings.animation_duration }};

    function easeOutQuart(t) {
      return 1 - Math.pow(1 - t, 4);
    }

    function animateNumber(element, target, suffix, animDuration) {
      const startTime = performance.now();

      function update(currentTime) {
        const elapsed = currentTime - startTime;
        const progress = Math.min(elapsed / animDuration, 1);
        const easedProgress = easeOutQuart(progress);
        const current = Math.floor(easedProgress * target);

        element.textContent = current + suffix;

        if (progress < 1) {
          requestAnimationFrame(update);
        } else {
          element.textContent = target + suffix;
        }
      }

      requestAnimationFrame(update);
    }

    function initStatsAnimation() {
      const wrapper = document.querySelector('.stats-animation-wrapper[data-stats-init]');
      if (!wrapper) return;

      const numbers = wrapper.querySelectorAll('[data-target]');
      let hasAnimated = false;

      const observer = new IntersectionObserver(
        function(entries) {
          entries.forEach(function(entry) {
            if (entry.isIntersecting && !hasAnimated) {
              hasAnimated = true;
              numbers.forEach(function(num) {
                const target = parseInt(num.getAttribute('data-target'), 10);
                const suffix = num.getAttribute('data-suffix') || '';
                animateNumber(num, target, suffix, duration);
              });
            }
          });
        },
        { threshold: 0.2 }
      );

      observer.observe(wrapper);
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStatsAnimation);
    } else {
      initStatsAnimation();
    }

    document.addEventListener('shopify:section:load', initStatsAnimation);
    document.addEventListener('shopify:block:select', initStatsAnimation);
  })();
</script>

