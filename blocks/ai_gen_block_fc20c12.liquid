{% doc %}
  @prompt
    Create a FAQ accordion section for a product page with collapsible questions and answers. Each item should expand/collapse when clicked with a smooth animation. Include a "+" icon that rotates to "×" when open. Style it with a clean, minimal dark premium aesthetic — thin divider lines between items, bold question text, and subtle expand/collapse transitions. The section should support multiple FAQ items that can be customized in the theme editor (title and content for each). Match the style shown: left-aligned bold question text, "+" icon on the right, full-width rows with top/bottom borders.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-faq-accordion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    margin: 0 auto;
  }

  .ai-faq-accordion__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.section_title_size }}px;
    font-weight: 700;
    margin: 0 0 {{ block.settings.title_spacing }}px;
    color: {{ block.settings.text_color }};
    text-align: {{ block.settings.title_alignment }};
  }

  .ai-faq-accordion__list-{{ ai_gen_id }} {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-faq-accordion__item-{{ ai_gen_id }} {
    border-top: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-faq-accordion__item-{{ ai_gen_id }}:last-child {
    border-bottom: {{ block.settings.divider_thickness }}px solid {{ block.settings.divider_color }};
  }

  .ai-faq-accordion__button-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.item_padding }}px 0;
    background: none;
    border: none;
    cursor: pointer;
    text-align: left;
    gap: 20px;
  }

  .ai-faq-accordion__question-{{ ai_gen_id }} {
    font-size: {{ block.settings.question_size }}px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0;
    flex: 1;
  }

  .ai-faq-accordion__icon-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: {{ block.settings.icon_size }}px;
    height: {{ block.settings.icon_size }}px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: {{ block.settings.icon_color }};
    transition: transform 0.3s ease;
  }

  .ai-faq-accordion__icon-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
  }

  .ai-faq-accordion__item-{{ ai_gen_id }}.active .ai-faq-accordion__icon-{{ ai_gen_id }} {
    transform: rotate(45deg);
  }

  .ai-faq-accordion__content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease, padding 0.3s ease;
  }

  .ai-faq-accordion__item-{{ ai_gen_id }}.active .ai-faq-accordion__content-{{ ai_gen_id }} {
    max-height: 1000px;
    padding-bottom: {{ block.settings.item_padding }}px;
  }

  .ai-faq-accordion__answer-{{ ai_gen_id }} {
    font-size: {{ block.settings.answer_size }}px;
    line-height: 1.6;
    color: {{ block.settings.answer_color }};
    margin: 0;
  }

  .ai-faq-accordion__answer-{{ ai_gen_id }} p {
    margin: 0 0 12px;
  }

  .ai-faq-accordion__answer-{{ ai_gen_id }} p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-faq-accordion__title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.section_title_size }}px * 0.85);
    }

    .ai-faq-accordion__question-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.question_size }}px * 0.9);
    }

    .ai-faq-accordion__answer-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.answer_size }}px * 0.9);
    }

    .ai-faq-accordion__button-{{ ai_gen_id }} {
      padding: {{ block.settings.item_padding | times: 0.8 }}px 0;
    }

    .ai-faq-accordion__item-{{ ai_gen_id }}.active .ai-faq-accordion__content-{{ ai_gen_id }} {
      padding-bottom: {{ block.settings.item_padding | times: 0.8 }}px;
    }
  }
{% endstyle %}

<faq-accordion-{{ ai_gen_id }} class="ai-faq-accordion-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.section_title != blank %}
    <h2 class="ai-faq-accordion__title-{{ ai_gen_id }}">{{ block.settings.section_title }}</h2>
  {% endif %}

  <ul class="ai-faq-accordion__list-{{ ai_gen_id }}">
    {% for i in (1..10) %}
      {% liquid
        assign question_key = 'question_' | append: i
        assign answer_key = 'answer_' | append: i
        assign question = block.settings[question_key]
        assign answer = block.settings[answer_key]
      %}

      {% if question != blank %}
        <li class="ai-faq-accordion__item-{{ ai_gen_id }}" data-faq-item>
          <button
            class="ai-faq-accordion__button-{{ ai_gen_id }}"
            aria-expanded="false"
            data-faq-button
          >
            <h3 class="ai-faq-accordion__question-{{ ai_gen_id }}">{{ question }}</h3>
            <span class="ai-faq-accordion__icon-{{ ai_gen_id }}" aria-hidden="true">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </span>
          </button>
          <div class="ai-faq-accordion__content-{{ ai_gen_id }}" data-faq-content>
            {% if answer != blank %}
              <div class="ai-faq-accordion__answer-{{ ai_gen_id }}">{{ answer }}</div>
            {% endif %}
          </div>
        </li>
      {% endif %}
    {% endfor %}
  </ul>
</faq-accordion-{{ ai_gen_id }}>

<script>
  (function() {
    class FaqAccordion{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-faq-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const button = item.querySelector('[data-faq-button]');
          const content = item.querySelector('[data-faq-content]');

          button.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            if (isActive) {
              this.closeItem(item, button, content);
            } else {
              this.openItem(item, button, content);
            }
          });
        });
      }

      openItem(item, button, content) {
        item.classList.add('active');
        button.setAttribute('aria-expanded', 'true');
        content.style.maxHeight = content.scrollHeight + 'px';
      }

      closeItem(item, button, content) {
        item.classList.remove('active');
        button.setAttribute('aria-expanded', 'false');
        content.style.maxHeight = '0';
      }
    }

    customElements.define('faq-accordion-{{ ai_gen_id }}', FaqAccordion{{ ai_gen_id }});
  })();
</script>

