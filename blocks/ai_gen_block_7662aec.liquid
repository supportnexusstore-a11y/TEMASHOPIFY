{% doc %}
  @prompt
    Create a statistics/benefits section with 3 columns of animated percentage numbers. IMPORTANT: The count-up animation MUST trigger using IntersectionObserver when the section scrolls into the viewport - NOT on page load. Use a plain function-based approach (NOT custom elements / HTMLElement classes) to avoid issues with Shopify's theme editor.
    
    LAYOUT:
    - Centered heading text at the top (e.g. "Benefícios comprovados, resultados comprovados") in regular weight
    - 3 equal columns side by side with large bold percentage numbers (e.g. "80%", "75%", "74%")
    - Below each number: a short bold subtitle
    - Below subtitle: small italic description/citation text
    - Clean white background, no borders or shadows
    
    ANIMATION (critical - must work on scroll):
    - Use IntersectionObserver with threshold: 0.2
    - Trigger count-up animation only when element enters viewport
    - Use requestAnimationFrame for smooth counting from 0 to target
    - Use easeOutQuart easing
    - Store suffix in data-suffix attribute on each number element
    - Use a simple init function called on DOMContentLoaded AND immediately for already-visible elements
    - Do NOT use customElements.define or HTMLElement classes
    
    All content editable in theme editor:
    - Section heading, heading color, heading size
    - For each of 3 stats: number value, suffix (default "%"), subtitle, description
    - Number color, size, weight
    - Subtitle color, size
    - Description color, size, style
    - Animation duration (ms)
    - Background color
    - Desktop width percentage
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-stats-section-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: 60px 20px;
  }

  .ai-stats-container-{{ ai_gen_id }} {
    max-width: {{ block.settings.desktop_width_percent }}%;
    margin: 0 auto;
  }

  .ai-stats-heading-{{ ai_gen_id }} {
    text-align: center;
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0 0 50px;
    font-weight: 400;
  }

  .ai-stats-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 40px;
  }

  .ai-stats-item-{{ ai_gen_id }} {
    text-align: center;
  }

  .ai-stats-number-{{ ai_gen_id }} {
    font-size: {{ block.settings.number_size }}px;
    font-weight: {{ block.settings.number_weight }};
    color: {{ block.settings.number_color }};
    margin: 0 0 15px;
    line-height: 1.2;
  }

  .ai-stats-subtitle-{{ ai_gen_id }} {
    font-size: {{ block.settings.subtitle_size }}px;
    font-weight: 700;
    color: {{ block.settings.subtitle_color }};
    margin: 0 0 10px;
  }

  .ai-stats-description-{{ ai_gen_id }} {
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    font-style: {{ block.settings.description_style }};
    margin: 0;
  }

  @media screen and (max-width: 749px) {
    .ai-stats-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 30px;
    }

    .ai-stats-heading-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.8);
      margin-bottom: 30px;
    }

    .ai-stats-number-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.number_size }}px * 0.8);
    }
  }
{% endstyle %}

<div class="ai-stats-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-stats-container-{{ ai_gen_id }}">
    {% if block.settings.heading != blank %}
      <h2 class="ai-stats-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    {% endif %}

    <div class="ai-stats-grid-{{ ai_gen_id }}" data-stats-container="{{ ai_gen_id }}">
      {% for i in (1..3) %}
        {% liquid
          assign number_key = 'stat_' | append: i | append: '_number'
          assign suffix_key = 'stat_' | append: i | append: '_suffix'
          assign subtitle_key = 'stat_' | append: i | append: '_subtitle'
          assign description_key = 'stat_' | append: i | append: '_description'

          assign number = block.settings[number_key]
          assign suffix = block.settings[suffix_key]
          assign subtitle = block.settings[subtitle_key]
          assign description = block.settings[description_key]
        %}

        <div class="ai-stats-item-{{ ai_gen_id }}">
          <div
            class="ai-stats-number-{{ ai_gen_id }}"
            data-stat-number="{{ ai_gen_id }}"
            data-target="{{ number }}"
            data-suffix="{{ suffix }}"
          >
            0{{ suffix }}
          </div>
          {% if subtitle != blank %}
            <div class="ai-stats-subtitle-{{ ai_gen_id }}">{{ subtitle }}</div>
          {% endif %}
          {% if description != blank %}
            <div class="ai-stats-description-{{ ai_gen_id }}">{{ description }}</div>
          {% endif %}
        </div>
      {% endfor %}
    </div>
  </div>
</div>

<script>
  (function() {
    function initStatsCounter{{ ai_gen_id }}() {
      const container = document.querySelector('[data-stats-container="{{ ai_gen_id }}"]');
      if (!container) return;

      const numbers = container.querySelectorAll('[data-stat-number="{{ ai_gen_id }}"]');
      let hasAnimated = false;

      function easeOutQuart(t) {
        return 1 - Math.pow(1 - t, 4);
      }

      function animateNumber(element) {
        const target = parseFloat(element.getAttribute('data-target'));
        const suffix = element.getAttribute('data-suffix');
        const duration = {{ block.settings.animation_duration }};
        const startTime = performance.now();

        function update(currentTime) {
          const elapsed = currentTime - startTime;
          const progress = Math.min(elapsed / duration, 1);
          const easedProgress = easeOutQuart(progress);
          const current = easedProgress * target;

          element.textContent = Math.round(current) + suffix;

          if (progress < 1) {
            requestAnimationFrame(update);
          } else {
            element.textContent = target + suffix;
          }
        }

        requestAnimationFrame(update);
      }

      function handleIntersection(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting && !hasAnimated) {
            hasAnimated = true;
            numbers.forEach(function(number) {
              animateNumber(number);
            });
            observer.unobserve(container);
          }
        });
      }

      const observer = new IntersectionObserver(handleIntersection, {
        threshold: 0.2
      });

      observer.observe(container);

      const rect = container.getBoundingClientRect();
      const isVisible = rect.top < window.innerHeight && rect.bottom > 0;
      if (isVisible) {
        hasAnimated = true;
        numbers.forEach(function(number) {
          animateNumber(number);
        });
        observer.unobserve(container);
      }
    }

    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initStatsCounter{{ ai_gen_id }});
    } else {
      initStatsCounter{{ ai_gen_id }}();
    }
  })();
</script>

