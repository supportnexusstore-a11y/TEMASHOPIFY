{% doc %}
  @prompt
    Create an infinite auto-scrolling logo ticker/carousel section for the online store. It should display a horizontal row of brand logos that scrolls continuously from right to left in a loop (marquee-style). The logos should be images uploaded by the merchant. The section should: have a seamless infinite loop animation with no pause or gaps, support customization of scroll speed, have a clean minimal dark background to match a premium electronics brand aesthetic, allow adding multiple logo images via the theme editor, duplicate the logos automatically to ensure the loop is seamless, and be fully responsive on mobile and desktop.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-logo-ticker-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    background-color: {{ block.settings.background_color }};
    padding: {{ block.settings.section_padding }}px 0;
    overflow: hidden;
    position: relative;
  }

  .ai-logo-ticker-track-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.logo_spacing }}px;
    animation: ai-logo-ticker-scroll-{{ ai_gen_id }} {{ block.settings.scroll_speed }}s linear infinite;
    will-change: transform;
  }

  .ai-logo-ticker-{{ ai_gen_id }}:hover .ai-logo-ticker-track-{{ ai_gen_id }} {
    {% if block.settings.pause_on_hover %}
      animation-play-state: paused;
    {% endif %}
  }

  .ai-logo-ticker-item-{{ ai_gen_id }} {
    flex-shrink: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ block.settings.logo_height }}px;
  }

  .ai-logo-ticker-item-{{ ai_gen_id }} img {
    max-height: 100%;
    width: auto;
    object-fit: contain;
    opacity: {{ block.settings.logo_opacity | divided_by: 100.0 }};
    transition: opacity 0.3s ease;
    filter: {{ block.settings.logo_filter }};
  }

  .ai-logo-ticker-item-{{ ai_gen_id }}:hover img {
    opacity: 1;
  }

  .ai-logo-ticker-placeholder-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    justify-content: center;
    height: {{ block.settings.logo_height }}px;
    width: 150px;
    background-color: rgba(255, 255, 255, 0.05);
    border-radius: 4px;
    flex-shrink: 0;
  }

  .ai-logo-ticker-placeholder-{{ ai_gen_id }} svg {
    width: 60px;
    height: 60px;
    opacity: 0.2;
  }

  @keyframes ai-logo-ticker-scroll-{{ ai_gen_id }} {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 749px) {
    .ai-logo-ticker-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding | times: 0.6 }}px 0;
    }

    .ai-logo-ticker-item-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.7 }}px;
    }

    .ai-logo-ticker-placeholder-{{ ai_gen_id }} {
      height: {{ block.settings.logo_height | times: 0.7 }}px;
      width: 100px;
    }
  }
{% endstyle %}

<logo-ticker-{{ ai_gen_id }} class="ai-logo-ticker-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-logo-ticker-track-{{ ai_gen_id }}">
    {% liquid
      assign logo_count = 0
      for i in (1..12)
        assign logo_key = 'logo_' | append: i
        if block.settings[logo_key] != blank
          assign logo_count = logo_count | plus: 1
        endif
      endfor
    %}

    {% if logo_count > 0 %}
      {% for duplicate in (1..2) %}
        {% for i in (1..12) %}
          {% liquid
            assign logo_key = 'logo_' | append: i
            assign logo = block.settings[logo_key]
          %}
          {% if logo != blank %}
            <div class="ai-logo-ticker-item-{{ ai_gen_id }}">
              <img
                src="{{ logo | image_url: width: 400 }}"
                alt="{{ logo.alt | escape }}"
                loading="lazy"
                width="{{ logo.width }}"
                height="{{ logo.height }}"
              >
            </div>
          {% endif %}
        {% endfor %}
      {% endfor %}
    {% else %}
      {% for duplicate in (1..2) %}
        {% for i in (1..8) %}
          <div class="ai-logo-ticker-placeholder-{{ ai_gen_id }}">
            {{ 'image' | placeholder_svg_tag }}
          </div>
        {% endfor %}
      {% endfor %}
    {% endif %}
  </div>
</logo-ticker-{{ ai_gen_id }}>

<script>
  (function() {
    class LogoTicker{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.track = this.querySelector('.ai-logo-ticker-track-{{ ai_gen_id }}');
        this.adjustAnimationSpeed();
      }

      adjustAnimationSpeed() {
        if (!this.track) return;
        
        const trackWidth = this.track.scrollWidth / 2;
        const speed = {{ block.settings.scroll_speed }};
        const duration = (trackWidth / 100) * (speed / 10);
        
        this.track.style.animationDuration = `${duration}s`;
      }
    }

    customElements.define('logo-ticker-{{ ai_gen_id }}', LogoTicker{{ ai_gen_id }});
  })();
</script>

