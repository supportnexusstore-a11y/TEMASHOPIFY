{%- style -%}
.comparison-table-section {
    position: relative;
  }
  .comparison-table-wave-header {
    width: 100%;
    height: 0;
    padding-bottom: 9%;
    position: relative;
    overflow: hidden;
    line-height: 0;
  }
  .comparison-table-wave-header__svg {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .comparison-table-wave-header__wave--back {
    opacity: 0.95;
  }
  .comparison-table-wave-header__wave--back2 {
    opacity: 0.9;
  }
.comparison-table{
    width: 100%;
    border-collapse: separate;
}
    .comparison-table-{{ section.id }} th,
    .comparison-table-{{ section.id }} td {
      padding-left: 1.25rem;
      padding-right: 1.25rem;
    }
    .comparison-table-{{ section.id }} .comparison-table__row-name,
    .comparison-table-{{ section.id }} th.comparison-table__others,
    .comparison-table-{{ section.id }} td:nth-child(3) {
      background: transparent !important;
    }
    .comparison-table-{{ section.id }} tbody tr:not(:last-child) .comparison-table__row-name,
    .comparison-table-{{ section.id }} tbody tr:not(:last-child) td:nth-child(3) {
      {% assign border_alpha = section.settings.us_column_bg_opacity | default: 100 | times: 0.01 %}
      {% if section.settings.us_column_bg_color != blank %}
      border-bottom: 1px solid {{ section.settings.us_column_bg_color | color_modify: 'alpha', border_alpha }};
      {% else %}
      border-bottom: 1px solid rgba(0, 0, 0, {{ border_alpha }});
      {% endif %}
    }
    .comparison-table__row-name {
        {% if section.settings.title_cell_bg != blank %}
        background: {{ section.settings.title_cell_bg }};
        {% else %}
        background: transparent;
        {% endif %}
    }
    .comparison-table__row-name h3 {
        color: {{ section.settings.title_cell_color }};
        font-weight: 600;
    }
    .comparison-table-background--{{ section.id }} {
      {% assign start = section.settings.comparison_bg_start | default: 0 %}
      background: linear-gradient(
        180deg,
        {{ section.settings.comparison_bg_color }} 0%,
        {{ section.settings.comparison_bg_color }} {{ start }}%,
        {{ section.settings.comparison_bg_color_end | default: section.settings.comparison_bg_color }} 100%
      );
    }
    .comparison-table-{{ section.id }} th:nth-child(2),
    .comparison-table-{{ section.id }} td:nth-child(2) {
      {% if section.settings.us_column_bg_color != blank %}
        {% assign us_alpha = section.settings.us_column_bg_opacity | default: 100 | times: 0.01 %}
        background: {{ section.settings.us_column_bg_color | color_modify: 'alpha', us_alpha }};
      {% endif %}
    }
    .comparison-table-{{ section.id }} thead tr th:nth-child(2) {
      border-top-left-radius: 12px;
      border-top-right-radius: 12px;
    }
    .comparison-table-{{ section.id }} tbody tr:last-child td:nth-child(2) {
      border-bottom-left-radius: 12px;
      border-bottom-right-radius: 12px;
    }
    .comparison-table-{{ section.id }} .comparison-table__logo {
      font-weight: 700;
      {% if section.settings.us_label_color != blank %}
      color: {{ section.settings.us_label_color }};
      {% endif %}
    }
    .comparison-table-{{ section.id }} th.comparison-table__others {
      {% if section.settings.others_label_color != blank %}
      color: {{ section.settings.others_label_color }};
      {% endif %}
    }
    .comparison-table-section--{{ section.id }} .content-container {
      display: flex;
      flex-direction: column;
      gap: {{ section.settings.content_gap | default: 28 }}px;
    }
    .comparison-table-section--{{ section.id }} .content-container h2 {
      color: {{ section.settings.heading_color | default: '#000000' }};
    }
    .comparison-table-section--{{ section.id }} .content-container .rte {
      color: {{ section.settings.text_color | default: '#4a4a4a' }};
    }
    .comparison-table-section--{{ section.id }} .content-container .button.mb-1em {
      padding-top: {{ section.settings.button_padding_vertical | default: 14 }}px;
      padding-bottom: {{ section.settings.button_padding_vertical | default: 14 }}px;
      padding-left: {{ section.settings.button_padding_horizontal | default: 28 }}px;
      padding-right: {{ section.settings.button_padding_horizontal | default: 28 }}px;
    }
    {% if section.settings.button_color != blank %}
    .comparison-table-section--{{ section.id }} .content-container .button.mb-1em {
      background: {{ section.settings.button_color | color_modify: 'alpha', 1 }} !important;
      border-color: {{ section.settings.button_color | color_modify: 'alpha', 1 }} !important;
      opacity: 1 !important;
    }
    {% endif %}
    {% if section.settings.button_text_color != blank %}
    .comparison-table-section--{{ section.id }} .content-container .button.mb-1em {
      color: {{ section.settings.button_text_color }};
    }
    {% endif %}
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
      padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
    }

    .comparison-table-section--{{ section.id }},
    .comparison-table-section--{{ section.id }} * {
      box-shadow: none !important;
      text-shadow: none !important;
    }
  
    @media screen and (min-width: 750px) {
      .section-{{ section.id }}-padding {
        padding-top: {{ section.settings.padding_top }}px;
        padding-bottom: {{ section.settings.padding_bottom }}px;
      }
    }
  
  {%- endstyle -%}
  
  <div class="comparison-table-section comparison-table-section--{{ section.id }} color-{{ section.settings.color_scheme }} content-for-grouping animate-section animate--hidden isolate {{ section.settings.visibility }}">
    {% if section.settings.display_id %}
      <copy-button class='section-id-btn button' data-content="#shopify-section-{{ section.id }}" data-success="false">
        <span class="copy-text">Click to copy section ID</span>
        <span class="copy-success">ID copied successfully!</span>
      </copy-button>
    {% endif %}
    <div class="comparison-table-wave-header" style="--wave-color-1: {{ section.settings.wave_color_1 }}; --wave-color-2: {{ section.settings.wave_color_2 }}; --wave-color-3: {{ section.settings.wave_color_2 }};">
      <svg class="comparison-table-wave-header__svg" viewBox="0 0 1200 120" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <path class="comparison-table-wave-header__wave comparison-table-wave-header__wave--back2" fill="var(--wave-color-3)" d="M0,90 C250,30 500,110 750,90 S1100,50 1200,90 V120 H0 Z"/>
        <path class="comparison-table-wave-header__wave comparison-table-wave-header__wave--back" fill="var(--wave-color-2)" d="M0,80 C200,20 400,120 600,80 S1000,20 1200,80 V120 H0 Z"/>
        <path class="comparison-table-wave-header__wave comparison-table-wave-header__wave--front" fill="var(--wave-color-1)" d="M0,60 C300,0 600,100 900,60 S1200,100 1200,60 V120 H0 Z"/>
      </svg>
    </div>
    <div class="comparison-table-background comparison-table-background--{{ section.id }}">
      <div class="comparison-table-content page-width section-{{ section.id }}-padding">
      <div class="content-and-comparison-table section-group__container__child-grid{% if section.settings.layout == 'table_first' %} content-and-comparison-table--table-first{% endif %}{% if section.settings.title == blank and section.settings.text == blank %} content-and-comparison-table--no-content{% endif %}">
        {% assign content_index = 0 %}
        <div class="content-container content-rte center animate-item animate-item--child index-0{% if section.settings.layout == 'table_first' %} desktop-index-1{% endif %}">
          {%- unless section.settings.title == blank -%}
            {% assign content_index = 1 %}
            <h2 class="{{ section.settings.heading_size }}">
              {{ section.settings.title }}
            </h2>
          {%- endunless -%}
          {%- unless section.settings.text == blank -%}
            {% assign content_index = 1 %}
            <div class="rte">
              {{ section.settings.text }}
            </div>
          {%- endunless -%}
          {%- if section.settings.button_label != blank -%}
            <a
              {% if section.settings.button_link != blank %}
                href="{{ section.settings.button_link }}"
              {% else %}
                role="link" aria-disabled="true"
              {% endif %}
              class="button mb-1em {% if section.settings.button_style_secondary %}button--secondary{% else %}button--primary{% endif %}"
            >
              {{- section.settings.button_label | escape -}}
            </a>
          {%- endif -%}
        </div>
        <div class="comparison-table-container flex-center animate-item animate-item--child index-{{ content_index }}{% if section.settings.layout == 'table_first' %} desktop-index-0{% endif %}">
          <table class="comparison-table comparison-table--{{ section.settings.style }} comparison-table-{{ section.id }}">
            <thead class='isolate'>
              <tr>
                <th>&nbsp</th>
                <th
                  align="center"
                  class="comparison-table__logo{% if section.settings.style == 'centered' %} color-{{ section.settings.highlighted_color_scheme }}{% endif %}"
                  style="--font-size: {{ section.settings.us_label_size | divided_by: 10.0 }}rem;"
                >
                  {%- if section.settings.logo != blank -%}
                    {{
                      section.settings.logo
                      | image_url: width: 400
                      | image_tag: alt: shop.name
                    }}
                  {%- else -%}
                    {{ section.settings.us_label | replace: '[shop_name]', shop.name }}
                  {%- endif -%}
                </th>
                <th class="comparison-table__others" align="center" style="--font-size: {{ section.settings.others_label_size | divided_by: 10.0 }}rem;">{{ section.settings.others_label }}</th>
              </tr>
            </thead>
            <tbody class='isolate'>
              {% liquid
                if section.settings.checkmark_style == 'solid' or section.settings.style == 'minimal'
                  assign solid_checkmark = true
                else
                  assign solid_checkmark = false
                endif
                if section.settings.x_style == 'solid' or section.settings.style == 'minimal'
                  assign solid_x = true
                else
                  assign solid_x = false
                endif
              %}
              {%- for block in section.blocks -%}
                <tr>
                  <td align="center" class="comparison-table__row-name{% if section.settings.style == 'centered' %} color-{{ section.settings.other_cells_color_scheme }} regular-cell{% elsif section.settings.style == 'classic' %} color-{{ section.settings.highlighted_color_scheme }} highlighted-cell{% endif %}">
                    <h3>{{ block.settings.benefit }}</h3>
                  </td>
                  <td align="center" class="{% if section.settings.style == 'centered' %}color-{{ section.settings.highlighted_color_scheme }} highlighted-cell{% elsif section.settings.style == 'classic' %}color-{{ section.settings.other_cells_color_scheme }} regular-cell{% endif %}">
                    {%- if block.settings.us -%}
                      <div class='comparison-table__icon flex-center{% if solid_checkmark %} comparison-table__icon--solid{% endif %}' style='--icon-color:{{ section.settings.checkmark_color }};--bg-color:{{ section.settings.checkmark_bg_color }}'>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
                          <path fill='currentColor' d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/>
                        </svg>
                      </div>
                    {%- else -%}
                      <div class='comparison-table__icon flex-center{% if solid_x %} comparison-table__icon--solid{% endif %}' style='{% if section.settings.opposite_icon_colors == 'original' %}--icon-color:{{ section.settings.x_color }};--bg-color:{{ section.settings.x_bg_color }}{% else %}--icon-color:{{ section.settings.checkmark_color }};--bg-color:{{ section.settings.checkmark_bg_color }}{% endif %}'>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512">
                          <path fill='currentColor' d="M342.6 150.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192 210.7 86.6 105.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L146.7 256 41.4 361.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192 301.3 297.4 406.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.3 256 342.6 150.6z"/>
                        </svg>
                      </div>
                    {%- endif -%}
                  </td>
                  <td align="center" class="regular-cell {% unless section.settings.style == 'minimal' %}color-{{ section.settings.other_cells_color_scheme }}{% endunless %}">
                    {%- if block.settings.others -%}
                      <div class='comparison-table__icon flex-center{% if solid_checkmark %} comparison-table__icon--solid{% endif %}' style='{% if section.settings.opposite_icon_colors == 'original' %}--icon-color:{{ section.settings.checkmark_color }};--bg-color:{{ section.settings.checkmark_bg_color }}{% else %}--icon-color:{{ section.settings.x_color }};--bg-color:{{ section.settings.x_bg_color }}{% endif %}'>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 448 512">
                          <path fill='currentColor' d="M438.6 105.4c12.5 12.5 12.5 32.8 0 45.3l-256 256c-12.5 12.5-32.8 12.5-45.3 0l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0L160 338.7 393.4 105.4c12.5-12.5 32.8-12.5 45.3 0z"/>
                        </svg>
                      </div>
                    {%- else -%}
                      <div class='comparison-table__icon flex-center{% if solid_x %} comparison-table__icon--solid{% endif %}' style='--icon-color:{{ section.settings.x_color }};--bg-color:{{ section.settings.x_bg_color }}'>
                        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 384 512">
                          <path fill='currentColor' d="M342.6 150.6c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L192 210.7 86.6 105.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3L146.7 256 41.4 361.4c-12.5 12.5-12.5 32.8 0 45.3s32.8 12.5 45.3 0L192 301.3 297.4 406.6c12.5 12.5 32.8 12.5 45.3 0s12.5-32.8 0-45.3L237.3 256 342.6 150.6z"/>
                        </svg>
                      </div>
                    {%- endif -%}
                  </td>
                </tr>
              {%- endfor -%}
            </tbody>
          </table>
        </div>
      </div>
    </div>
    </div>
  </div>
  
  {% schema %}
  {
    "name": "Comparison table",
    "settings": [
      {
        "type": "header",
        "content": "Wave header"
      },
      {
        "type": "color",
        "id": "wave_color_1",
        "label": "Wave color (front)",
        "default": "#ff6b9d"
      },
      {
        "type": "color",
        "id": "wave_color_2",
        "label": "Wave color (background 1)",
        "default": "#c44d8a"
      },
      {
        "type": "header",
        "content": "Comparison area"
      },
      {
        "type": "color",
        "id": "comparison_bg_color",
        "label": "Background color (start)",
        "default": "#f8f8f9"
      },
      {
        "type": "color",
        "id": "comparison_bg_color_end",
        "label": "Background color (end)",
        "default": "#e8e8f0"
      },
      {
        "type": "range",
        "id": "comparison_bg_start",
        "label": "Onde o gradiente começa (%)",
        "min": 0,
        "max": 100,
        "step": 1,
        "unit": "%",
        "default": 0
      },
      {
        "type": "header",
        "content": "General"
      },
      {
        "type": "text",
        "id": "title",
        "default": "Comparison table",
        "label": "Heading"
      },
      {
        "type": "select",
        "id": "heading_size",
        "options": [
          {
            "value": "h2",
            "label": "t:sections.all.heading_size.options__1.label"
          },
          {
            "value": "h1",
            "label": "t:sections.all.heading_size.options__2.label"
          },
          {
            "value": "h0",
            "label": "t:sections.all.heading_size.options__3.label"
          }
        ],
        "default": "h1",
        "label": "t:sections.all.heading_size.label"
      },
      {
        "type": "richtext",
        "id": "text",
        "default": "<p>Talk about how and why is your brand better than the others.</p>",
        "label": "Text"
      },
      {
        "type": "color",
        "id": "heading_color",
        "label": "Heading color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "text_color",
        "label": "Description color",
        "default": "#4a4a4a"
      },
      {
        "type": "range",
        "id": "content_gap",
        "min": 8,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Space between heading, description and button",
        "default": 28
      },
      {
        "type": "header",
        "content": "Button"
      },
      {
        "type": "text",
        "id": "button_label",
        "label": "Button text",
        "info": "Leave blank to hide the button."
      },
      {
        "type": "url",
        "id": "button_link",
        "label": "Button link"
      },
      {
        "type": "color",
        "id": "button_color",
        "label": "Button color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "button_text_color",
        "label": "Button text color",
        "default": "#ffffff"
      },
      {
        "type": "range",
        "id": "button_padding_vertical",
        "min": 6,
        "max": 40,
        "step": 2,
        "unit": "px",
        "label": "Button vertical padding",
        "default": 14
      },
      {
        "type": "range",
        "id": "button_padding_horizontal",
        "min": 12,
        "max": 60,
        "step": 2,
        "unit": "px",
        "label": "Button horizontal padding",
        "default": 28
      },
      {
        "type": "checkbox",
        "id": "button_style_secondary",
        "label": "t:sections.slideshow.blocks.slide.settings.secondary_style.label",
        "default": false
      },
      {
        "type": "header",
        "content": "Table"
      },
      {
        "type": "color",
        "id": "title_cell_bg",
        "label": "Title cell color",
        "default": "#000"
      },
      {
        "type": "color",
        "id": "title_cell_color",
        "label": "Title cell text",
        "default": "#FFF"
      },
      {
        "type": "select",
        "id": "layout",
        "options": [
          {
            "value": "table_first",
            "label": "Table first"
          },
          {
            "value": "table_second",
            "label": "Table second"
          }
        ],
        "default": "table_second",
        "label": "Desktop table placement"
      },
      {
        "type": "select",
        "id": "style",
        "options": [
          {
            "value": "classic",
            "label": "Classic"
          },
          {
            "value": "centered",
            "label": "Centered"
          },
          {
            "value": "minimal",
            "label": "Minimalistic"
          }
        ],
        "default": "classic",
        "label": "Table style"
      },
      {
        "type": "image_picker",
        "id": "logo",
        "label": "Logo"
      },
      {
        "type": "text",
        "id": "us_label",
        "label": "Us label",
        "default": "[shop_name]",
        "info": "Displayed if logo image is not selected."
      },
      {
        "type": "range",
        "id": "us_label_size",
        "min": 12,
        "max": 28,
        "step": 1,
        "unit": "px",
        "label": "Us label font size",
        "default": 18
      },
      {
        "type": "color",
        "id": "us_label_color",
        "label": "Us label color",
        "default": "#000000"
      },
      {
        "type": "color",
        "id": "us_column_bg_color",
        "label": "Background color of \"Us\" column",
        "default": "#ffffff"
      },
      {
        "type": "range",
        "id": "us_column_bg_opacity",
        "min": 0,
        "max": 100,
        "step": 5,
        "unit": "%",
        "label": "Opacity of \"Us\" column",
        "default": 100
      },
      {
        "type": "text",
        "id": "others_label",
        "label": "Competitors label",
        "default": "Others"
      },
      {
        "type": "range",
        "id": "others_label_size",
        "min": 12,
        "max": 28,
        "step": 1,
        "unit": "px",
        "label": "Competitors label font size",
        "default": 18
      },
      {
        "type": "color",
        "id": "others_label_color",
        "label": "Competitors label color",
        "default": "#000000"
      },
      {
        "type": "header",
        "content": "Icons"
      },
      {
        "type": "color",
        "id": "checkmark_color",
        "default": "#53AF01",
        "label": "Checkmark color"
      },
      {
        "type": "color",
        "id": "x_color",
        "default": "#121212",
        "label": "X color"
      },
      {
        "type": "select",
        "id": "opposite_icon_colors",
        "options": [
          {
            "value": "original",
            "label": "Original"
          },
          {
            "value": "inverse",
            "label": "Inverse"
          }
        ],
        "default": "original",
        "label": "Opposite icons color",
        "info": "Color of the checkmark when it's in \"others\" and X when it's in \"us\"."
      },
      {
        "type": "header",
        "content": "t:sections.all.padding.section_padding_heading"
      },
      {
        "type": "range",
        "id": "padding_top",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_top",
        "default": 36
      },
      {
        "type": "range",
        "id": "padding_bottom",
        "min": 0,
        "max": 100,
        "step": 4,
        "unit": "px",
        "label": "t:sections.all.padding.padding_bottom",
        "default": 36
      }
    ],
    "blocks": [
      {
        "type": "row",
        "name": "Table row",
        "settings": [
          {
            "type": "text",
            "id": "benefit",
            "default": "Benefit",
            "label": "Benefit"
          },
          {
            "type": "checkbox",
            "id": "us",
            "default": true,
            "label": "Us"
          },
          {
            "type": "checkbox",
            "id": "others",
            "default": false,
            "label": "Others"
          }
        ]
      }
    ],
    "presets": [
      {
        "name": "Comparison table",
        "blocks": [
          {
            "type": "row"
          },
          {
            "type": "row"
          },
          {
            "type": "row"
          }
        ]
      }
    ],
    "disabled_on": {
      "groups": ["header", "footer"]
    }
  }
  {% endschema %}
  