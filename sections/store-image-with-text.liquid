{% assign section_padding = 'padding-top: ' | append: section.settings.padding_top | append: 'px; padding-bottom: ' | append: section.settings.padding_bottom | append: 'px; margin-top: ' | append: section.settings.margin_top | append: 'px; margin-bottom: ' | append: section.settings.margin_bottom | append: 'px;' %}

{% assign gradient_style = '' %}

{% if section.settings.gradient != blank %}
  {% assign gradient_style = 'background: ' | append: section.settings.gradient | append: ';' %}
{% endif %}


<div class="storebuild-layout" style="{{ section_padding }}{{ gradient_style }}">

  <div class="storebuild-container storebuild-mx-auto storebuild-w-full storebuild-p-4">
    <div class="storebuild-flex storebuild-flex-col storebuild-gap-8">

      {% if section.settings.heading != blank %}
        <h2 class="{{ section.settings.heading_size }} storebuild-text-{{ section.settings.heading_mobilealignment }} sm:storebuild-text-{{ section.settings.heading_alignment }}" style="color: {{ section.settings.heading_color }};">
          {{ section.settings.heading }}
        </h2>
      {% endif %}

      {% if section.settings.text != blank %}
        <div class="storebuild-w-full {% if section.settings.text_alignment == 'center' %}storebuild-max-w-4xl storebuild-mx-auto{% endif %}">
          <div class="{{ section.settings.text_style }} storebuild-text-{{ section.settings.text_mobilealignment }} sm:storebuild-text-{{ section.settings.text_alignment }}" style="color: {{ section.settings.text_color }};" {{ section.shopify_attributes }}>
            {{ section.settings.text }}
          </div>
        </div>
      {% endif %}

    </div>

    <div class="storebuild-w-full storebuild-items-center storebuild-justify-center storebuild-flex storebuild-flex-col sm:storebuild-grid storebuild-grid-cols-1 md:storebuild-grid-cols-4 storebuild-gap-y-10 md:storebuild-gap-10 storebuild-mt-10">
      <div class="storebuild-w-full storebuild-px-6 storebuild-grid storebuild-grid-cols-2 storebuild-justify-normal storebuild-items-start md:storebuild-flex md:storebuild-flex-col storebuild-mx-auto md:storebuild-items-center md:storebuild-justify-center storebuild-gap-12 sm:storebuild-order-1 storebuild-order-3">
        {% for block in section.blocks limit:2 %}
          <div class="storebuild-flex storebuild-flex-col storebuild-items-center storebuild-justify-center storebuild-text-center storebuild-gap-2" {{ block.shopify_attributes }}>
            <div class="
              {% if block.settings.emoji_size == 'small' %}storebuild-text-4xl
              {% elsif block.settings.emoji_size == 'medium' %}storebuild-text-5xl
              {% else %}storebuild-text-6xl{% endif %}
            ">
              {{ block.settings.emoji }}
            </div>
            <div class="{{ block.settings.heading_size }}" style="color: {{ block.settings.heading_color }};">
              {{ block.settings.heading }}
            </div>
            <div class="storebuild-w-full storebuild-break-words {{ block.settings.text_style }}" style="color: {{ block.settings.text_color }};">
              {{ block.settings.text }}
            </div>
          </div>
        {% endfor %}
      </div>
      <div class="storebuild-px-6 storebuild-col-span-2 storebuild-flex storebuild-items-center storebuild-justify-center storebuild-order-2">

          {% assign image_width_class = '' %}

          {% case section.settings.desktop_image_width %}
            {% when 'small' %}
              {% assign image_width_class = 'storebuild-max-w-lg' %}
            {% when 'medium' %}
              {% assign image_width_class = 'storebuild-max-w-2xl' %}
            {% when 'large' %}
              {% assign image_width_class = 'storebuild-max-w-4xl' %}
          {% endcase %}

        {% assign image_class = 'storebuild-w-full ' | append: image_width_class | append: ' ' | append: rounded_class %}

        {% assign border_radius = section.settings.image_border_radius | times: 1 %}

        {% if border_radius == 100 %}
          {% assign border_radius = 99999 %}
        {% endif %}

        {% if section.settings.image %}
        <img src="{{ section.settings.image | img_url: 'master' }}"
              alt="{{ section.settings.image.alt | escape }}"
              loading="lazy"
              class="{{ image_class }}"
            style="border-radius: {{ border_radius }}px;"
              width="{{ section.settings.image.width }}"
              height="{{ section.settings.image.height }}">
        {% else %}
        <div class="storebuild-w-full storebuild-h-full {{ image_width_class }}">
          <img src="{{ 'storebuild-image-placeholder.svg' | asset_url }}" alt="Storebuild AI Shopify Product" class="storebuild-w-full storebuild-h-full" style="border-radius: {{ border_radius }}px; border: 1px solid #d1d5db;" />
        </div>
        {% endif %}

      </div>
      <div class="storebuild-w-full storebuild-px-6 storebuild-grid storebuild-grid-cols-2 storebuild-justify-normal storebuild-items-start md:storebuild-flex md:storebuild-flex-col storebuild-mx-auto md:storebuild-items-center md:storebuild-justify-center storebuild-gap-12 storebuild-order-3">
        {% for block in section.blocks offset:2 limit:2 %}
          <div class="storebuild-flex storebuild-flex-col storebuild-items-center storebuild-justify-center storebuild-text-center storebuild-gap-2" {{ block.shopify_attributes }}>
            <div class="
              {% if block.settings.emoji_size == 'small' %}storebuild-text-4xl
              {% elsif block.settings.emoji_size == 'medium' %}storebuild-text-5xl
              {% else %}storebuild-text-6xl{% endif %}
            ">
              {{ block.settings.emoji }}
            </div>
            <div class="{{ block.settings.heading_size }}" style="color: {{ block.settings.heading_color }};">
              {{ block.settings.heading }}
            </div>
            <div class="storebuild-w-full storebuild-break-words {{ block.settings.text_style }}" style="color: {{ block.settings.text_color }};">
              {{ block.settings.text }}
            </div>
          </div>
        {% endfor %}
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "storebuild - Benefits",
  "settings": [
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "desktop_image_width",
      "options": [
        { "value": "small", "label": "Small" },
        { "value": "medium", "label": "Medium" },
        { "value": "large", "label": "Large" }
      ],
      "default": "large",
      "label": "Image size",
      "info": "Image is automatically optimized for mobile."
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "min": 0,
      "max": 100,
      "step": 25,
      "unit": "%",
      "label": "Rounded Corners",
      "default": 100
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "inline_richtext",
      "id": "heading",
      "default": "Transform your store with smart features",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" },
        { "value": "hxl", "label": "Extra large" },
        { "value": "hxxl", "label": "Extra extra large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Alignment"
    },
    {
      "type": "select",
      "id": "heading_mobilealignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Mobile alignment"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Text"
    },
    {
      "type": "richtext",
      "id": "text",
      "default": "<p>Boost your conversions with a clean, fast, and persuasive product section powered by Storebuild AI. Launch faster and sell smarter.</p>",
      "label": "Text"
    },
    {
      "type": "select",
      "id": "text_style",
      "options": [
        { "value": "body", "label": "Small" },
        { "value": "subtitle", "label": "Large" }
      ],
      "default": "subtitle",
      "label": "Text size"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Alignment"
    },
    {
      "type": "select",
      "id": "text_mobilealignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center",
      "label": "Mobile alignment"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Color"
    },
    {
      "type": "color_background",
      "id": "gradient",
      "label": "Background color"
    },
    {
      "type": "header",
      "content": "Section padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top padding",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom padding",
      "default": 0
    },
    {
      "type": "header",
      "content": "Section margin"
    },
    {
      "type": "range",
      "id": "margin_top",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Top margin",
      "default": 0
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "min": 0,
      "max": 200,
      "step": 4,
      "unit": "px",
      "label": "Bottom margin",
      "default": 0
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Benefit",
      "limit": 4,
      "settings": [
        {
          "type": "text",
          "id": "emoji",
          "label": "Emoji",
          "default": "🚀"
        },
        {
          "type": "select",
          "id": "emoji_size",
          "options": [
            { "value": "small", "label": "Small" },
            { "value": "medium", "label": "Medium" },
            { "value": "large", "label": "Large" }
          ],
          "default": "medium",
          "label": "Emoji size"
        },
        {
          "type": "inline_richtext",
          "id": "heading",
          "default": "Fast Performance",
          "label": "Heading"
        },
        {
          "type": "select",
          "id": "heading_size",
          "options": [
            { "value": "h4", "label": "Small" },
            { "value": "h3", "label": "Medium" },
            { "value": "h2", "label": "Large" }
          ],
          "default": "h3",
          "label": "Heading size"
        },
        {
          "type": "color",
          "id": "heading_color",
          "label": "Heading color",
          "default": "#000000"
        },
        {
          "type": "richtext",
          "id": "text",
          "default": "<p>Your site loads in seconds to keep customers engaged.</p>",
          "label": "Text"
        },
        {
          "type": "select",
          "id": "text_style",
          "options": [
            { "value": "body", "label": "Small" },
            { "value": "subtitle", "label": "Large" }
          ],
          "default": "body",
          "label": "Text size"
        },
        {
          "type": "color",
          "id": "text_color",
          "label": "Text color",
          "default": "#000000"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Image With Benefits",
      "blocks": [
        {
          "type": "benefit",
          "settings": {
            "emoji": "🚀",
            "heading": "Fast Performance",
            "text": "<p>Your site loads in seconds to keep customers engaged.</p>"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji": "🔒",
            "heading": "Secure Checkout",
            "text": "<p>Protect your customers and build trust with every sale.</p>"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji": "⚡️",
            "heading": "Easy Customization",
            "text": "<p>Tailor each section to your brand in just a few clicks.</p>"
          }
        },
        {
          "type": "benefit",
          "settings": {
            "emoji": "💼",
            "heading": "Professional Design",
            "text": "<p>Look legit with clean, modern layouts optimized for sales.</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}

