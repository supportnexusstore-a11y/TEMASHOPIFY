            "list_heading": "Quick start guide"
          }
        },
        {
          "type": "right",
          "settings": {
            "list_heading": "Automated process"
          }
        },
        {
          "type": "right",
          "settings": {
            "list_heading": "Better outcomes"
          }
        }
      ]
    }
  ]
}
{% endschema %}