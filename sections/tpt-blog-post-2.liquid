

{% comment %} Section layout style {% endcomment %}
{{ 'tpt-section.css' | asset_url | stylesheet_tag }}

{% comment %} Section configuration {% endcomment %}
{%- render 'tpt-section-setting', section: section -%}

{%- if section.index and section.settings.section_lazyload -%}
  <script src="{{ 'tpt-section-lazyload.js' | asset_url }}" defer="defer"></script>

  <tpt-section-lazyload data-url="?section_id={{ section.id }}">
    <div data-lazyload-element></div>
    <span class="tpt-section_loader"></span>
  </tpt-section-lazyload>
{%- else -%}
  {% comment %} Current section style {% endcomment %}
  {{ 'tpt-grid.css' | asset_url | stylesheet_tag }}
  {{ 'tpt-blog-post-2.css' | asset_url | stylesheet_tag }}

  {%- capture sizes -%}
    (min-width: 1281px) calc(100vw / {{ section.settings.desktop_column }}), (min-width: 992px) calc(100vw / {{ section.settings.tablet_column }}), 100vw
  {%- endcapture -%}

  <div class="tpt-section_container">
    <div class="tpt-section_content">
      {% comment %} Section header {% endcomment %}
      {%- render 'tpt-section-header', section: section -%}

      <div class="tpt-section-body">
        {% comment %} Section body {% endcomment %}
        <div class="tpt-blog-post-2-container">
          <div class="tpt-blog-post-2-list-item tpt-grid desktop-{{ section.settings.desktop_column }}-columns tablet-{{ section.settings.tablet_column }}-columns mobile-{{ section.settings.mobile_column }}-columns">
            {%- if section.settings.blog != blank -%}
              {%- for article in section.settings.blog.articles limit: section.settings.blog_limit -%}
                <div class="tpt-blog-post-2-item tpt-grid_item">
                  <div
                    class="tpt-blog-post-2-item-image"
                    style="--ratio-percent: {{ section.settings.image_ratio | divided_by: 100.0 }};"
                  >
                    <a
                      class="tpt-block__image-link"
                      href="{{ article.url }}"
                      aria-label="{{ article.title }}"
                      >&nbsp;</a
                    >

                    {%- if article.image.src != blank -%}
                      {% assign image_alt = article.image.alt | default: shop.name %}

                      {{
                        article.image
                        | image_url: width: article.image.width
                        | image_tag:
                          widths: '490, 640, 768, 1024, 1280, 1366, 1440, 1640, 1920',
                          sizes: sizes,
                          width: article.image.width,
                          height: article.image.height,
                          alt: image_alt,
                          loading: 'lazy'
                      }}
                    {%- else -%}
                      {%- render 'tpt-image-placeholder' -%}
                    {%- endif -%}
                  </div>
                  <div class="tpt-blog-post-2-item-information tpt-section__foreground--color">
                    {%- if section.settings.show_author or section.settings.show_date -%}
                      <div class="tpt-blog__user-date">
                        {%- if section.settings.show_author -%}
                          <div class="blog-user">
                            {{ article.author }}
                          </div>
                        {%- endif -%}

                        {%- if section.settings.show_date -%}
                          <div class="blog-date">{{ article.published_at | time_tag: format: 'date' }}</div>
                        {%- endif -%}
                      </div>
                    {%- endif -%}

                    <h3 class="tpt-blog__heading h5">
                      <a href="{{ article.url }}">
                        {{ article.title | escape }}
                      </a>
                    </h3>

                    {%- if section.settings.show_excerpt -%}
                      {%- if article.excerpt.size > 0 or article.content.size > 0 -%}
                        <div class="tpt-blog-post-1-item-information-description tpt-section__foreground--color">
                          {%- if article.excerpt.size > 0 -%}
                            {{ article.excerpt | strip_html | truncatewords: 20 }}
                          {%- else -%}
                            {{ article.content | strip_html | truncatewords: 20 }}
                          {%- endif -%}
                        </div>
                      {%- endif -%}
                    {%- endif -%}

                    {%- if section.settings.readmore_label != blank -%}
                      <div class="tpt-blog__more">
                        <a
                          href="{{ article.url }}"
                          class="tpt-blog-post-1-item-information-link tpt-section__foreground--color"
                        >
                          {{- section.settings.readmore_label -}}
                        </a>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {% endfor %}
            {% else %}
              {%- for i in (1..section.settings.blog_limit) -%}
                <div class="tpt-blog-post-2-item tpt-grid_item">
                  <div
                    class="tpt-blog-post-2-item-image"
                    style="--ratio-percent: {{ section.settings.image_ratio | divided_by: 100.0 }};"
                  >
                    <a
                      class="tpt-block__image-link"
                      href="#"
                      aria-label="Block post title example"
                      >&nbsp;</a
                    >

                    {%- render 'tpt-image-placeholder' -%}
                  </div>
                  <div class="tpt-blog-post-2-item-information tpt-section__foreground--color">
                    <h3 class="tpt-blog__heading h5">
                      <a href="#"> Blog post title example </a>
                    </h3>

                    {%- if section.settings.readmore_label != blank -%}
                      <div class="tpt-blog__more">
                        <a
                          href="#"
                          class="tpt-blog-post-1-item-information-link tpt-section__foreground--color"
                        >
                          {{- section.settings.readmore_label -}}
                        </a>
                      </div>
                    {%- endif -%}
                  </div>
                </div>
              {% endfor %}
            {% endif %}
          </div>
        </div>
        {% comment %} End section body {% endcomment %}
      </div>

      {% comment %} Section footer {% endcomment %}
      {%- render 'tpt-section-footer', section: section -%}
    </div>
  </div>
{%- endif -%}{%- unless content_for_header contains 'tapita-section-script-tags' -%}{% style %}#shopify-section-{{ section.id }}{display: none !important;}{% endstyle %}{%- endunless -%}


{% schema %}
