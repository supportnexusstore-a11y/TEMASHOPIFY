{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .multicolumn--{{ section.id }} .splide__list {
    display: flex;
    gap: 0;
    margin: calc(-{{ section.settings.gap }}px / 2);
  }

  .multicolumn--{{ section.id }} .splide__slide {
    width: calc(100% - {{ section.settings.gap }}px);
    margin: calc({{ section.settings.gap }}px / 2);
  }

  /* Mobile: mostrar um pedaço do próximo card (peek) */
  @media screen and (max-width: 749px) {
    .multicolumn--{{ section.id }} .splide:not(.splide--destroy-mobile) .splide__slide {
      width: calc(85% - {{ section.settings.gap }}px);
    }
  }

  @media screen and (min-width: 750px) {
    .multicolumn--{{ section.id }} .splide__slide {
      width: calc({{ 100.0 | divided_by: section.settings.testimonials_per_row }}% - {{ section.settings.gap }}px);
    }
  }

  /* Carrossel ativo: uma linha só, sem quebrar; scroll horizontal */
  .multicolumn--{{ section.id }} .splide:not(.splide--destroy-desktop) .splide__list {
    flex-wrap: nowrap;
  }
  .multicolumn--{{ section.id }} .splide:not(.splide--destroy-desktop) .splide__slide {
    flex-shrink: 0;
  }
  .multicolumn--{{ section.id }} .splide:not(.splide--destroy-mobile) .splide__list {
    flex-wrap: nowrap;
  }
  .multicolumn--{{ section.id }} .splide:not(.splide--destroy-mobile) .splide__slide {
    flex-shrink: 0;
  }
  /* Track com scroll horizontal quando carrossel ativo; barra de scroll oculta */
  .multicolumn--{{ section.id }} .splide:not(.splide--destroy-desktop) .splide__track {
    overflow-x: auto;
    overflow-y: hidden;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }
  .multicolumn--{{ section.id }} .splide:not(.splide--destroy-desktop) .splide__track::-webkit-scrollbar {
    display: none;
  }
  @media screen and (max-width: 749px) {
    .multicolumn--{{ section.id }} .splide:not(.splide--destroy-mobile) .splide__track {
      overflow-x: auto;
      overflow-y: hidden;
      -webkit-overflow-scrolling: touch;
      scrollbar-width: none;
      -ms-overflow-style: none;
    }
    .multicolumn--{{ section.id }} .splide:not(.splide--destroy-mobile) .splide__track::-webkit-scrollbar {
      display: none;
    }
  }

  /* Movimento infinito (ticker) – igual ao horizontal-ticker */
  .multicolumn--{{ section.id }} .testimonial-ticker {
    overflow: hidden;
    width: 100%;
  }
  .multicolumn--{{ section.id }} .testimonial-ticker__container {
    display: flex;
    flex-wrap: nowrap;
    gap: 0;
    width: 200%;
    {% assign _ticker_speed = section.settings.infinite_ticker_speed | default: 3 %}
    animation: testimonialTicker-{{ section.id }} {{ 150 | divided_by: _ticker_speed }}s linear infinite forwards;
  }
  .multicolumn--{{ section.id }} .testimonial-ticker__container .testimonial-ticker__slide {
    flex-shrink: 0;
    box-sizing: border-box;
    /* Duas cópias dos blocos: 50% do container = uma volta; cada slide = 50% / quantidade de blocos */
    width: calc(50% / {{ section.blocks.size }});
    padding: 0 calc({{ section.settings.gap }}px / 2);
  }

  /* Mobile: largura fixa por card no ticker para não distorcer (evita afinar/esticar) */
  @media screen and (max-width: 749px) {
    .multicolumn--{{ section.id }} .testimonial-ticker__container .testimonial-ticker__slide {
      width: 300px;
      min-width: 300px;
    }
  }

  @keyframes testimonialTicker-{{ section.id }} {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
{%- endstyle -%}

<div class="multicolumn multicolumn--{{ section.id }} color-{{ section.settings.color_scheme }} gradient{% if section.settings.title == blank %} no-heading{% endif %} content-for-grouping animate-section animate--hidden {{ section.settings.visibility }}">
  {%- liquid
    assign has_mobile_slider = false
    assign has_desktop_slider = false
    assign has_infinite_ticker = false
    if section.settings.enable_carousel
      assign has_mobile_slider = true
      assign has_desktop_slider = true
      if section.settings.enable_infinite_ticker
        assign has_infinite_ticker = true
      endif
    endif

    assign highest_ratio = 0
    for block in section.blocks
      if block.settings.video.aspect_ratio > highest_ratio
        assign highest_ratio = block.settings.video.aspect_ratio
      elsif block.settings.image.aspect_ratio > highest_ratio
        assign highest_ratio = block.settings.image.aspect_ratio
      endif
    endfor
    assign bg_diff_class = ' multicolumn--same-bgs'
    unless section.settings.color_scheme == section.settings.cards_color_scheme
      assign bg_diff_class = ' multicolumn--diff-bgs'
    endunless
  -%}
  <div
    class="page-width{% if section.settings.desktop_full_page %} desktop-full-page{% endif %}{% if has_mobile_slider %} mobile-full-page{% endif %} section-{{ section.id }}-padding isolate"
    style="--columns-desktop: {{ section.settings.testimonials_per_row }};--columns-mobile:1;--gap-desktop:{{ section.settings.gap | divided_by: 10.0 }}rem;--gap-mobile:1.5rem;"
  >
    <div class="animate-item animate-item--child index-0">
      {% assign content_index = 0 %}
      {%- unless section.settings.title == blank -%}
        {% assign content_index = 1 %}
        <h2 class="title center inline-richtext h1 scroll-trigger animate--slide-in {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      {%- endunless -%}
      {% if section.settings.text != blank %}
        {% assign content_index = 1 %}
        <div class="multicolumn-text">
          {{ section.settings.text }}
        </div>
      {% endif %}
    </div>
    {% if has_infinite_ticker %}
    <div class="testimonial-ticker">
      <div class="testimonial-ticker__container">
        {% for run in (1..2) %}
          {% for block in section.blocks %}
            <div class="testimonial-ticker__slide">
              <div class="splide__slide__container" style="--index:{{ forloop.index0 | plus: content_index }};" {{ block.shopify_attributes }}>
                <div class="multicolumn-card content-container testimonial-card color-{{ section.settings.cards_color_scheme }}{{ bg_diff_class }}{% if section.settings.column_alignment == 'center' %} center{% endif %}{% unless block.settings.author_avatar == blank and block.settings.author == blank %} testimonial-card--has-author{% endunless %} animate-item animate-item--child">
                  {%- if block.settings.image != blank or block.settings.video != blank -%}
                    {% if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' %}
                      {% assign spaced_image = true %}
                    {% endif %}
                    <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width">
                      <div
                        class="media media--transparent media--{{ section.settings.image_ratio }}"
                        {% if section.settings.image_ratio == 'adapt' %}
                          style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                        {% endif %}
                      >
                        {% if block.settings.video == blank %}
                          {%- capture sizes -%}
                                (min-width: 990px) {% if section.blocks.size <= 2 %}710px{% else %}550px{% endif %}, (min-width:
                                750px) {% if section.blocks.size == 1 %}710px{% else %}550px{% endif %}, calc(100vw - 30px)
                              {%- endcapture -%}
                          {{
                            block.settings.image
                            | image_url: width: 1420
                            | image_tag:
                              loading: 'lazy',
                              sizes: sizes,
                              widths: '275, 550, 710, 1420',
                              class: 'multicolumn-card__image'
                          }}
                        {% else %}
                          <internal-video class="internal-video">
                            {% liquid
                              if block.settings.video_thumbnail != blank
                                assign thumbnail = block.settings.video_thumbnail
                              else
                                assign thumbnail = block.settings.video.preview_image
                              endif
                            %}
                            <video
                              width="100%"
                              height="auto"
                              preload="metadata"
                              poster="{{ thumbnail | image_url }}"
                              playsinline
                              disablepictureinpicture
                            >
                              {% for source in block.settings.video.sources %}
                                <source
                                  {% if block.settings.muted_autoplay %}
                                    data-
                                  {% endif -%}
                                  src="{{ source.url }}"
                                  type="{{ source.mime_type }}"
                                >
                              {% endfor %}
                            </video>
                            <button class="internal-video__play">
                              <div class="play-button color-accent-1">
                                {%- render 'icon-play' -%}
                              </div>
                            </button>
                            <div class="internal-video__timeline">&nbsp</div>
                          </internal-video>
                        {% endif %}
                      </div>
                    </div>
                  {%- endif -%}
                  {%- liquid
                    if block.settings.card_gradient_top != blank and block.settings.card_gradient_bottom != blank
                      assign card_has_gradient = true
                      assign card_bg = block.settings.card_gradient_top
                    else
                      assign card_has_gradient = false
                      assign card_bg = section.settings.background_color
                    endif
                  -%}
                  <div class="multicolumn-card__info testimonial-card__info--image-on-top{% if block.settings.image != blank %} testimonial-card__info--has-top-image{% endif %}{% if block.settings.image == blank and section.settings.show_stars == false %} testimonial-card__info--no-image-no-stars{% endif %}{% if block.settings.image != blank and section.settings.show_stars == false %} testimonial-card__info--image-no-stars{% endif %}" style="--card-bg: {{ card_bg }};{% if card_has_gradient %} background: linear-gradient(180deg, {{ block.settings.card_gradient_top }} 0%, {{ block.settings.card_gradient_bottom }} 100%); background-color: transparent;{% endif %}">
                    {%- unless block.settings.author_avatar == blank and block.settings.author == blank -%}
                      <div class="testimonial-card__author-container{% if block.settings.image != blank %} testimonial-card__author-container--overlap{% endif %}">
                        {%- if block.settings.author_avatar != blank -%}
                          <div class="testimonial-card__avatar testimonial-card__avatar--circular">
                            {{
                              block.settings.author_avatar
                              | image_url: width: 150
                              | image_tag: loading: 'lazy', width: 100
                            }}
                          </div>
                        {%- endif -%}
                        {%- if block.settings.author != blank -%}
                          <p class="testimonial-card__author"{% if block.settings.card_author_color != blank %} style="color: {{ block.settings.card_author_color }};"{% endif %}>
                            {{ block.settings.author }}
                          </p>
                        {%- endif -%}
                      </div>
                    {%- endunless -%}
                    {%- if block.settings.title != blank -%}
                      <h3 class="testimonial-card__title"{% if block.settings.card_title_color != blank %} style="color: {{ block.settings.card_title_color }};"{% endif %}>{{ block.settings.title }}</h3>
                    {%- endif -%}
                    {%- if section.settings.show_stars -%}
                      <p class="testimonial-card__stars"{% if block.settings.card_stars_color != blank %} style="color: {{ block.settings.card_stars_color }};"{% endif %}>
                        ★★★★★
                      </p>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="rte testimonial-card__text"{% if block.settings.card_text_color != blank %} style="color: {{ block.settings.card_text_color }};"{% endif %}>{{ block.settings.text }}</div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </div>
          {% endfor %}
        {% endfor %}
      </div>
    </div>
    {% else %}
    <splide-component
      data-type="slide"
      data-autoplay="{% if section.settings.carousel_autoplay %}true{% else %}false{% endif %}"
      data-autoplay-speed="{{ section.settings.carousel_speed | times: 1000 }}"
      data-autoplay-interval="{{ section.settings.carousel_speed | times: 1000 }}"
      data-interval="{{ section.settings.carousel_speed | times: 1000 }}"
      data-slides-desktop="{{ section.settings.testimonials_per_row }}"
      data-per-move-desktop="1"
      data-gap-desktop="{{ section.settings.gap }}"
      data-slides-mobile="1"
      data-gap-mobile="15"
      data-side-padding-mobile="15"
      {% if has_desktop_slider == false %}
        data-destroy-desktop="true"
      {% endif %}
      {% if has_mobile_slider == false %}
        data-destroy-mobile="true"
      {% endif %}
    >
    <div
      id="testimonials-splide-{{ section.id }}"
      class="splide splide--desktop-dots-bottom splide--mobile-dots-bottom splide--desktop-arrows-outside splide--mobile-arrows-outside{% if has_desktop_slider == false %} splide--destroy-desktop{% endif %}{% if has_mobile_slider == false %} splide--destroy-mobile{% endif %}"
      style="--columns-desktop: {{ section.settings.testimonials_per_row }};--columns-mobile:1;--gap-desktop:{{ section.settings.gap | divided_by: 10.0 }}rem;--gap-mobile:1.5rem;"
    >
      <div class="splide__track">
        <ul class="splide__list">
          {%- for block in section.blocks -%}
            <li class="splide__slide">
              <div
                class="splide__slide__container"
                style="--index:{{ forloop.index0 | plus: content_index }};"
                {{ block.shopify_attributes }}
              >
                <div class="multicolumn-card content-container testimonial-card color-{{ section.settings.cards_color_scheme }}{{ bg_diff_class }}{% if section.settings.column_alignment == 'center' %} center{% endif %}{% unless block.settings.author_avatar == blank and block.settings.author == blank %} testimonial-card--has-author{% endunless %} animate-item animate-item--child">
                  {%- if block.settings.image != blank or block.settings.video != blank -%}
                    {% if section.settings.image_ratio == 'adapt' or section.settings.image_ratio == 'circle' %}
                      {% assign spaced_image = true %}
                    {% endif %}
                    <div class="multicolumn-card__image-wrapper multicolumn-card__image-wrapper--{{ section.settings.image_width }}-width">
                      <div
                        class="media media--transparent media--{{ section.settings.image_ratio }}"
                        {% if section.settings.image_ratio == 'adapt' %}
                          style="padding-bottom: {{ 1 | divided_by: highest_ratio | times: 100 }}%;"
                        {% endif %}
                      >
                        {% if block.settings.video == blank %}
                          {%- capture sizes -%}
                                (min-width: 990px) {% if section.blocks.size <= 2 %}710px{% else %}550px{% endif %}, (min-width:
                                750px) {% if section.blocks.size == 1 %}710px{% else %}550px{% endif %}, calc(100vw - 30px)
                              {%- endcapture -%}
                          {{
                            block.settings.image
                            | image_url: width: 1420
                            | image_tag:
                              loading: 'lazy',
                              sizes: sizes,
                              widths: '275, 550, 710, 1420',
                              class: 'multicolumn-card__image'
                          }}
                        {% else %}
                          <internal-video class="internal-video">
                            {% liquid
                              if block.settings.video_thumbnail != blank
                                assign thumbnail = block.settings.video_thumbnail
                              else
                                assign thumbnail = block.settings.video.preview_image
                              endif
                            %}
                            <video
                              width="100%"
                              height="auto"
                              preload="metadata"
                              poster="{{ thumbnail | image_url }}"
                              playsinline
                              disablepictureinpicture
                            >
                              {% for source in block.settings.video.sources %}
                                <source
                                  {% if block.settings.muted_autoplay %}
                                    data-
                                  {% endif -%}
                                  src="{{ source.url }}"
                                  type="{{ source.mime_type }}"
                                >
                              {% endfor %}
                            </video>
                            <button class="internal-video__play">
                              <div class="play-button color-accent-1">
                                {%- render 'icon-play' -%}
                              </div>
                            </button>
                            <div class="internal-video__timeline">&nbsp</div>
                          </internal-video>
                        {% endif %}
                      </div>
                    </div>
                  {%- endif -%}
                  {%- liquid
                    if block.settings.card_gradient_top != blank and block.settings.card_gradient_bottom != blank
                      assign card_has_gradient = true
                      assign card_bg = block.settings.card_gradient_top
                    else
                      assign card_has_gradient = false
                      assign card_bg = section.settings.background_color
                    endif
                  -%}
                  <div class="multicolumn-card__info testimonial-card__info--image-on-top{% if block.settings.image != blank %} testimonial-card__info--has-top-image{% endif %}{% if block.settings.image == blank and section.settings.show_stars == false %} testimonial-card__info--no-image-no-stars{% endif %}{% if block.settings.image != blank and section.settings.show_stars == false %} testimonial-card__info--image-no-stars{% endif %}" style="--card-bg: {{ card_bg }};{% if card_has_gradient %} background: linear-gradient(180deg, {{ block.settings.card_gradient_top }} 0%, {{ block.settings.card_gradient_bottom }} 100%); background-color: transparent;{% endif %}">
                    {%- unless block.settings.author_avatar == blank and block.settings.author == blank -%}
                      <div class="testimonial-card__author-container{% if block.settings.image != blank %} testimonial-card__author-container--overlap{% endif %}">
                        {%- if block.settings.author_avatar != blank -%}
                          <div class="testimonial-card__avatar testimonial-card__avatar--circular">
                            {{
                              block.settings.author_avatar
                              | image_url: width: 150
                              | image_tag: loading: 'lazy', width: 100
                            }}
                          </div>
                        {%- endif -%}
                        {%- if block.settings.author != blank -%}
                          <p class="testimonial-card__author"{% if block.settings.card_author_color != blank %} style="color: {{ block.settings.card_author_color }};"{% endif %}>
                            {{ block.settings.author }}
                          </p>
                        {%- endif -%}
                      </div>
                    {%- endunless -%}
                    {%- if block.settings.title != blank -%}
                      <h3 class="testimonial-card__title"{% if block.settings.card_title_color != blank %} style="color: {{ block.settings.card_title_color }};"{% endif %}>{{ block.settings.title }}</h3>
                    {%- endif -%}
                    {%- if section.settings.show_stars -%}
                      <p class="testimonial-card__stars"{% if block.settings.card_stars_color != blank %} style="color: {{ block.settings.card_stars_color }};"{% endif %}>
                        ★★★★★
                      </p>
                    {%- endif -%}
                    {%- if block.settings.text != blank -%}
                      <div class="rte testimonial-card__text"{% if block.settings.card_text_color != blank %} style="color: {{ block.settings.card_text_color }};"{% endif %}>{{ block.settings.text }}</div>
                    {%- endif -%}
                  </div>
                </div>
              </div>
            </li>
          {%- endfor -%}
        </ul>
      </div>
      <div class="splide__dots-and-arrows">
        <ul class="splide__pagination"></ul>
        <div class="splide__arrows"></div>
      </div>
    </div>
    </splide-component>
    {% endif %}
  </div>
</div>

<style>
  .multicolumn--{{ section.id }} .multicolumn-card {
    display: flex;
    flex-direction: column;
    overflow: visible;
  }
  .multicolumn--{{ section.id }} .multicolumn-card__image-wrapper {
    order: 1;
    width: 100%;
    position: relative;
    min-height: 320px;
    flex-shrink: 0;
    line-height: 0;
    border-radius: 10px 10px 0 0;
    overflow: hidden;
  }
  .multicolumn--{{ section.id }} .multicolumn-card__image-wrapper .media {
    position: relative;
    min-height: 320px;
    aspect-ratio: 4 / 3;
    display: block;
    overflow: hidden;
    border-radius: 10px 10px 0 0;
  }
  .multicolumn--{{ section.id }} .multicolumn-card__image-wrapper .media img,
  .multicolumn--{{ section.id }} .multicolumn-card__image-wrapper .media .multicolumn-card__image {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    max-width: 100%;
    object-fit: cover;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    right: 0;
    bottom: 0;
    border-radius: 10px 10px 0 0;
  }
  .multicolumn--{{ section.id }} .multicolumn-card__image-wrapper .media picture {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    border-radius: 10px 10px 0 0;
    overflow: hidden;
  }
  .multicolumn--{{ section.id }} .multicolumn-card__image-wrapper .media picture img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 10px 10px 0 0;
  }
  .multicolumn--{{ section.id }} .multicolumn-card__info {
    order: 2;
    background-color: {{ section.settings.background_color }};
    padding: 2rem 1.75rem 2rem;
    padding-top: calc(2rem + 2.5rem);
    text-align: center;
    position: relative;
    z-index: 0;
  }
  .multicolumn--{{ section.id }} .testimonial-card__info--has-top-image .testimonial-card__author-container--overlap {
    display: flex;
    flex-direction: column;
    align-items: center;
    position: absolute;
    left: 50%;
    top: 1rem;
    transform: translate(-50%, -50%);
    z-index: 2;
    margin-top: 0;
    margin-bottom: 0;
    padding-top: 0;
  }
  .multicolumn--{{ section.id }} .testimonial-card__info--has-top-image {
    padding-top: calc(2rem + 2.5rem + 0.75rem);
  }
  .multicolumn--{{ section.id }} .testimonial-card__info:not(.testimonial-card__info--has-top-image) .testimonial-card__author-container {
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-top: 0.75rem;
    margin-bottom: 0.75rem;
  }
  .multicolumn--{{ section.id }} .testimonial-card__avatar--circular {
    width: 5rem;
    height: 5rem;
    border-radius: 50%;
    overflow: hidden;
    border: 3px solid var(--card-bg, {{ section.settings.background_color }});
    flex-shrink: 0;
    margin-bottom: 0.5rem;
    box-shadow: 0 2px 12px rgba(0,0,0,0.15);
  }
  .multicolumn--{{ section.id }} .testimonial-card__avatar--circular img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }
  .multicolumn--{{ section.id }} .testimonial-card__author {
    margin: 0 0 0.5rem;
    font-weight: 600;
    color: {{ section.settings.author_color }};
  }
  .multicolumn--{{ section.id }} .testimonial-card__title {
    margin: 0 0 0.75rem;
    font-size: 1em;
    color: {{ section.settings.title_color }};
  }
  .multicolumn--{{ section.id }} .testimonial-card__stars {
    margin: 0 0 0.75rem;
    color: {{ section.settings.stars_color }};
  }
  .multicolumn--{{ section.id }} .testimonial-card__text {
    margin: 0;
    font-size: 0.95em;
    line-height: 1.6;
    color: {{ section.settings.text_color }};
  }
  .testimonial-image {
    max-width: 100%;
    border-radius: calc(var(--media-radius) - var(--media-border-width));
  }
</style>

{% schema %}
{
  "name": "Testimonials",
  "class": "section",
  "tag": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Testimonials",
      "label": "Heading"
    },
    {
      "type": "range",
      "id": "testimonials_per_row",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 3,
      "label": "Testimonials per row"
    },
    {
      "type": "range",
      "id": "gap",
      "min": 0,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 20,
      "label": "Gap between testimonials"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "checkbox",
      "id": "enable_carousel",
      "default": true,
